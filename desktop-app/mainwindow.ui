    <string notr="true">QWidget#centralwidget {
    background: #ffffff;
}

QLabel {
    color: #1c1c1e;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.2px;
}

QLabel#labelHello {
    font-size: 32px;
    font-weight: 700;
}

QPushButton {
    background: #ffffff;
    border: 1px solid #d2d2d7;
    border-radius: 12px;
    padding: 10px 16px;
    font-size: 16px;
    color: #1c1c1e;
}

QPushButton:hover {
    background: #fafafa;
}

QPushButton:pressed {
    background: #f2f2f7;
}

QSlider::groove:horizontal {
    height: 6px;
    background: #e5e5ea;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #ffffff;
    border: 1px solid #d2d2d7;
    width: 20px;
    margin: -7px 0;
    border-radius: 10px;
}
QSlider::sub-page:horizontal {
    background: #0a84ff;
    border-radius: 3px;
}</string>
